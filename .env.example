# API Configuration
# NEXT_PUBLIC_API_URL=https://flowapi.nodes-hub.com
NEXT_PUBLIC_API_URL=https://flowapi.nodes-hub.com
# Active des logs API cote navigateur
NEXT_PUBLIC_DEBUG_API=false

# Supabase (required for auth/session + media uploads)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase Storage (optional)
NEXT_PUBLIC_MEDIA_UPLOAD_BUCKET=mms-media
NEXT_PUBLIC_MAX_MEDIA_SIZE_MB=50


